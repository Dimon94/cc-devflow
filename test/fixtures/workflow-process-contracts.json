{
  "serialWorkflow": {
    "stages": [
      {
        "stage": "cc-plan",
        "handoff": "task.md",
        "next": "cc-do"
      },
      {
        "stage": "cc-do",
        "selection": "assigned task block",
        "verification": "verified diff",
        "next": "cc-check"
      },
      {
        "stage": "cc-check",
        "verdicts": ["pass", "fail", "blocked"],
        "next": "cc-act"
      },
      {
        "stage": "cc-act",
        "closeoutInput": "confirmed lessons"
      }
    ]
  },
  "parallelEnvironment": {
    "fields": [
      "DependsOn",
      "Parallel",
      "Assigned task IDs",
      "Touches",
      "Mutable resources",
      "Verification"
    ],
    "boundary": ["CHILD DISPATCH START", "CHILD DISPATCH END"],
    "finalReport": [
      "Environment",
      "Route",
      "Status",
      "Task file",
      "Assigned task IDs",
      "Thread",
      "Worktree",
      "Branch",
      "Commit",
      "Verification",
      "Dirty state",
      "Touched files",
      "Blockers",
      "Route recommendation"
    ],
    "integrationGate": [
      "clean worktree",
      "commit proof",
      "touched-path audit",
      "focused verification",
      "integration owner"
    ]
  },
  "qualityGate": {
    "findings": ["P0", "P1", "P2", "P3"],
    "verificationVerdicts": ["pass", "fail", "blocked"],
    "ledgerCandidate": "review escape",
    "classification": ["confirmed-lesson", "noise", "unresolved-risk"],
    "closeoutInput": "confirmed lessons"
  },
  "authoringGate": {
    "chainSkills": [
      "skill-authoring-gate",
      "task-contract",
      "workflow-chain-contract",
      "quality-gate-contract",
      "execution-environment-contract"
    ],
    "readerSkills": ["cc-dev", "cc-plan", "cc-do", "cc-check", "cc-review", "cc-act"],
    "mustNotHave": ["triggers"],
    "completionCriteria": [
      "invocation class",
      "checkable",
      "reliable pointer",
      "stale instructions were removed"
    ]
  }
}
