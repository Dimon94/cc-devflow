{
    "version": "4.1",
    "description": "Skill activation triggers for CC-DevFlow. Keep the visible surface to roadmap plus the PDCA loop.",
    "skills": {
        "roadmap": {
            "type": "workflow",
            "enforcement": "suggest",
            "priority": "high",
            "description": "路线图阶段。处理项目愿景、阶段目标、长期优先级与 backlog 主线。",
            "promptTriggers": {
                "keywords": [
                    "roadmap",
                    "product direction",
                    "project strategy",
                    "long term plan",
                    "mid term plan",
                    "backlog"
                ],
                "intentPatterns": [
                    "(plan|define|reset|rethink).*?(roadmap|direction|strategy|backlog|project)",
                    "(what|which).*?(next quarter|next stage|roadmap|direction)",
                    "(project|product).*?(future|wedge|focus|priority)"
                ]
            }
        },
        "req-plan": {
            "type": "workflow",
            "enforcement": "suggest",
            "priority": "high",
            "description": "Plan 阶段。处理需求澄清、方案设计、任务拆解。",
            "promptTriggers": {
                "keywords": [
                    "clarify requirement",
                    "scope this",
                    "design this",
                    "brainstorm",
                    "TASKS.md",
                    "task-manifest",
                    "plan this",
                    "REQ-"
                ],
                "intentPatterns": [
                    "(plan|clarify|scope|design|brainstorm|break down).*?(requirement|feature|bug|task|req)",
                    "(what|why).*?(build|fix|plan).*?(requirement|feature|bug)",
                    "(generate|refresh|rebuild).*?(tasks\\.md|task-manifest)"
                ]
            }
        },
        "req-do": {
            "type": "workflow",
            "enforcement": "suggest",
            "priority": "high",
            "description": "Do 阶段。处理编码、调试、恢复执行、review 回改。",
            "promptTriggers": {
                "keywords": [
                    "implement",
                    "build this",
                    "code this",
                    "fix bug",
                    "debug",
                    "resume work",
                    "review feedback",
                    "failing test"
                ],
                "intentPatterns": [
                    "(implement|build|code|develop|resume).*?(feature|task|req|requirement)",
                    "(fix|debug|investigate|root cause).*?(bug|error|issue|failure)",
                    "(address|handle|apply).*?(review|feedback|comments)"
                ]
            }
        },
        "req-check": {
            "type": "workflow",
            "enforcement": "suggest",
            "priority": "high",
            "description": "Check 阶段。处理验证、质量门、完成判定。",
            "promptTriggers": {
                "keywords": [
                    "verify",
                    "quality gate",
                    "run tests",
                    "is this done",
                    "ship ready",
                    "review diff",
                    "done?"
                ],
                "intentPatterns": [
                    "(verify|check|validate|review).*?(done|ready|quality|release)",
                    "(can we|is it).*?(ship|release|done|ready)",
                    "(run|execute).*?(tests|lint|typecheck|checks)"
                ]
            }
        },
        "req-act": {
            "type": "workflow",
            "enforcement": "suggest",
            "priority": "high",
            "description": "Act 阶段。处理交付、发布、文档同步、下一轮回写。",
            "promptTriggers": {
                "keywords": [
                    "prepare pr",
                    "release",
                    "ship this",
                    "handoff",
                    "release note",
                    "pr brief",
                    "sync docs"
                ],
                "intentPatterns": [
                    "(ship|release|deliver|handoff|merge).*?(req|feature|branch|work)",
                    "(prepare|create|write).*?(pr|brief|release|handoff|docs)",
                    "(what).*?(after check|next after verify|final step)"
                ]
            }
        },
        "task-order-guard": {
            "type": "guardrail",
            "enforcement": "block",
            "priority": "critical",
            "description": "阻止 TASKS.md 中出现实现先于测试完成的顺序错误。",
            "fileTriggers": {
                "pathPatterns": [
                    "devflow/requirements/**/TASKS.md"
                ],
                "contentPatterns": [
                    "\\[x\\].*Implementation.*\\n.*\\[ \\].*Test",
                    "\\[x\\].*Implement.*\\n.*\\[ \\].*Test"
                ]
            },
            "blockMessage": "⚠️ BLOCKED - Task order violation\\n\\n在 TASKS.md 中发现实现先于测试完成。先修正任务顺序，再继续进入 req-do。"
        },
        "artifact-guard": {
            "type": "guardrail",
            "enforcement": "block",
            "priority": "critical",
            "description": "阻止半成品文档或疑似秘密进入规划、验证与交付工件。",
            "fileTriggers": {
                "pathPatterns": [
                    "ROADMAP.md",
                    "BACKLOG.md",
                    "devflow/requirements/**/BRAINSTORM.md",
                    "devflow/requirements/**/DESIGN.md",
                    "devflow/requirements/**/TASKS.md",
                    "devflow/requirements/**/task-manifest.json",
                    "devflow/requirements/**/report-card.json",
                    "devflow/requirements/**/RELEASE_NOTE.md",
                    "devflow/intent/**/artifacts/pr-brief.md"
                ],
                "contentPatterns": [
                    "TODO.*later",
                    "FIXME",
                    "\\[placeholder\\]",
                    "simplified for now",
                    "defer to v\\d",
                    "API_KEY\\s*=\\s*['\"]?[a-zA-Z0-9_-]{10,}",
                    "SECRET\\s*=\\s*['\"]?[a-zA-Z0-9_-]+",
                    "PASSWORD\\s*=\\s*['\"]?[^\\s]+",
                    "TOKEN\\s*=\\s*['\"]?[a-zA-Z0-9_-]{10,}"
                ]
            },
            "blockMessage": "⚠️ BLOCKED - Artifact guard\\n\\n检测到半成品内容或疑似硬编码秘密。先清理，再进入 req-check / req-act。"
        }
    }
}
