{
  "name": "spec-alignment-team",
  "version": "2.0.0",
  "description": "flow-spec 的本地 Team 对齐配置：先澄清事实，再收敛计划，最后产出可执行任务图。",
  "mode": "parallel",
  "lead": "spec-lead",
  "members": [
    {
      "id": "clarify-analyst",
      "role": "analyst",
      "description": "梳理目标、约束与未知项",
      "outputs": [
        "devflow/intent/{REQ}/facts.md"
      ]
    },
    {
      "id": "tech-architect",
      "role": "architect",
      "description": "给出实现边界、接口和风险",
      "outputs": [
        "devflow/intent/{REQ}/artifacts/results/architecture.md"
      ]
    },
    {
      "id": "ui-designer",
      "role": "designer",
      "description": "补充界面与交互约束",
      "outputs": [
        "devflow/intent/{REQ}/artifacts/results/ui.md"
      ]
    },
    {
      "id": "planner",
      "role": "planner",
      "description": "将确认后的范围编译成执行计划和任务图",
      "outputs": [
        "devflow/intent/{REQ}/plan.md",
        "devflow/requirements/{REQ}/task-manifest.json"
      ]
    }
  ],
  "workflow": {
    "stages": [
      {
        "id": "stage-1",
        "name": "Fact Capture",
        "description": "收敛目标、约束与未决问题",
        "agents": [
          "clarify-analyst"
        ],
        "parallel": false,
        "outputs": [
          "devflow/intent/{REQ}/facts.md"
        ],
        "wait_for": []
      },
      {
        "id": "stage-2",
        "name": "Design Alignment",
        "description": "技术与界面角色并行补充实施边界",
        "agents": [
          "tech-architect",
          "ui-designer"
        ],
        "parallel": true,
        "outputs": [
          "devflow/intent/{REQ}/artifacts/results/architecture.md",
          "devflow/intent/{REQ}/artifacts/results/ui.md"
        ],
        "wait_for": [
          "stage-1"
        ],
        "negotiate": {
          "enabled": true,
          "topics": [
            "scope_boundary",
            "interface_shape",
            "risk_hotspots"
          ]
        }
      },
      {
        "id": "stage-3",
        "name": "Plan Compile",
        "description": "把对齐后的结论编译为计划与任务图",
        "agents": [
          "planner"
        ],
        "parallel": false,
        "outputs": [
          "devflow/intent/{REQ}/plan.md",
          "devflow/requirements/{REQ}/task-manifest.json"
        ],
        "wait_for": [
          "stage-2"
        ]
      }
    ]
  },
  "communication": {
    "protocol": "append_only_markdown_bus",
    "negotiate_topics": [
      {
        "id": "scope_boundary",
        "name": "范围边界",
        "description": "明确本轮必须完成与明确不做的部分",
        "participants": [
          "clarify-analyst",
          "tech-architect",
          "planner"
        ],
        "decision_owner": "spec-lead",
        "template": "建议本轮范围锁定为 {scope}，非目标为 {non_goals}，原因是 {reason}。"
      },
      {
        "id": "interface_shape",
        "name": "接口形状",
        "description": "统一输入输出、状态边界与调用约定",
        "participants": [
          "tech-architect",
          "ui-designer",
          "planner"
        ],
        "decision_owner": "tech-architect",
        "template": "建议接口形状采用 {shape}，关键字段包括 {fields}，以保证实现与界面一致。"
      },
      {
        "id": "risk_hotspots",
        "name": "风险热点",
        "description": "识别最容易拖慢自动驾驶的高风险点",
        "participants": [
          "tech-architect",
          "planner"
        ],
        "decision_owner": "planner",
        "template": "当前最高风险是 {risk}，缓解动作是 {mitigation}，若失败则回退到 {fallback}。"
      }
    ],
    "decision_record": {
      "path": "devflow/intent/{REQ}/decision-log.md",
      "format": "markdown",
      "template": "## {topic_name}\n\n**Decision**: {decision}\n**Participants**: {participants}\n**Reason**: {reason}\n**Time**: {timestamp}\n"
    }
  },
  "quality_gates": {
    "entry": {
      "required_files": [
        "devflow/intent/{REQ}/summary.md"
      ],
      "optional_files": [
        "devflow/intent/{REQ}/facts.md"
      ]
    },
    "exit": {
      "required_files": [
        "devflow/intent/{REQ}/plan.md",
        "devflow/requirements/{REQ}/task-manifest.json"
      ],
      "optional_files": [
        "devflow/intent/{REQ}/artifacts/results/architecture.md",
        "devflow/intent/{REQ}/artifacts/results/ui.md"
      ],
      "status_update": "planned"
    }
  },
  "error_handling": {
    "stage_failure": {
      "stage-1": {
        "action": "abort",
        "status": "planning_failed",
        "message": "Fact capture failed"
      },
      "stage-2": {
        "action": "continue_partial",
        "message": "Design alignment partially failed, continue with available evidence"
      },
      "stage-3": {
        "action": "abort",
        "status": "planning_failed",
        "message": "Plan compile failed"
      }
    },
    "teammate_failure": {
      "max_retries": 2,
      "retry_delay_seconds": 5
    }
  }
}
