{
    "name": "cc-devflow",
    "version": "4.5.40",
    "description": "Multi-platform CLI and skill pack for agent coding",
    "main": "bin/cc-devflow.js",
    "bin": {
        "cc-devflow": "bin/cc-devflow-cli.js"
    },
    "files": [
        "bin/",
        "lib/",
        "config/",
        "docs/assets/",
        ".claude/skills/cc-next/",
        ".claude/skills/cc-dev/",
        ".claude/skills/cc-plan/",
        ".claude/skills/cc-diagnose/",
        ".claude/skills/cc-do/",
        ".claude/skills/cc-review/",
        ".claude/skills/cc-pr-review/",
        ".claude/skills/cc-pr-land/",
        ".claude/skills/cc-check/",
        ".claude/skills/cc-act/",
        ".claude/skills/cc-simplify/",
        "docs/",
        "README.md",
        "README.zh-CN.md",
        "CONTRIBUTING.md",
        "CONTRIBUTING.zh-CN.md",
        "CODE_OF_CONDUCT.md",
        "CODE_OF_CONDUCT.zh-CN.md",
        "SECURITY.md",
        "SECURITY.zh-CN.md",
        "CHANGELOG.md",
        "LICENSE",
        "package.json"
    ],
    "publishConfig": {
        "access": "public"
    },
    "license": "MIT",
    "scripts": {
        "prepublishOnly": "node scripts/validate-publish.js",
        "test": "jest",
        "verify": "npm test && npm run verify:examples && npm run benchmark:skills",
        "verify:examples": "bash docs/examples/scripts/check-example-bindings.sh",
        "verify:publish": "node scripts/validate-publish.js",
        "benchmark:skills": "node scripts/benchmark-skills.js",
        "start": "node bin/cc-devflow.js",
        "adapt": "node bin/adapt.js",
        "adapt:check": "node bin/adapt.js --check",
        "adapt:skills": "node bin/adapt.js --skills",
        "adapt:rules": "node bin/adapt.js --rules",
        "adapt:codex": "node bin/adapt.js --platform codex",
        "adapt:cursor": "node bin/adapt.js --platform cursor",
        "adapt:qwen": "node bin/adapt.js --platform qwen",
        "adapt:antigravity": "node bin/adapt.js --platform antigravity"
    },
    "dependencies": {
        "@iarna/toml": "^2.2.5",
        "gray-matter": "^4.0.3",
        "js-yaml": "^4.1.0",
        "zod": "^3.22.4"
    },
    "devDependencies": {
        "jest": "^29.7.0"
    },
    "engines": {
        "node": ">=18"
    }
}
